# Copy to .env for local development (never commit .env).

# -----------------------------------------------------------------------------
# DATABASE_URL
# -----------------------------------------------------------------------------
# Local: use a real Postgres URL, e.g. Docker or localhost:
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/DATABASE?schema=public"
#
# Railway: do NOT paste the private URL into this file. In Railway → your
# **API** service (not Postgres) → Variables, add:
#   Name:  DATABASE_URL
#   Value: ${{ Postgres.DATABASE_URL }}
# If your database service is not named "Postgres", use the reference Railway
# suggests (Variable Reference → Postgres / your DB service).
# -----------------------------------------------------------------------------

# Required in production (NODE_ENV=production). Use a long random string.
JWT_SECRET="change-me-in-production-use-long-random-string"

# API listen port (staging platforms often set PORT via the host)
PORT=3001

# Optional: comma-separated allowed web origins for CORS (e.g. https://app.example.com,https://www.example.com)
# If unset, all origins are allowed (development-friendly; set in staging/production).
# CORS_ORIGIN="https://your-frontend-host.example"

# Optional: set to "production" in staging/production
# NODE_ENV=production
