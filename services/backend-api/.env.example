# PostgreSQL (staging: use your provider connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Required in production (NODE_ENV=production). Use a long random string.
JWT_SECRET="change-me-in-production-use-long-random-string"

# API listen port (staging platforms often set PORT via the host)
PORT=3001

# Optional: comma-separated allowed web origins for CORS (e.g. https://app.example.com,https://www.example.com)
# If unset, all origins are allowed (development-friendly; set in staging/production).
# CORS_ORIGIN="https://your-frontend-host.example"

# Optional: set to "production" in staging/production
# NODE_ENV=production
