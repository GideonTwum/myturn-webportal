# Public API base URL — the NestJS backend (not the Next.js site), including /api prefix.
# Local:    http://localhost:3001/api
# Staging:  https://backend-api-production-9f20.up.railway.app/api
# Do NOT use your Vercel frontend URL here (e.g. *.vercel.app without the API).
NEXT_PUBLIC_API_URL=http://localhost:3001/api
